style.
    /* Base Styles */
    body {
        margin: 0;
        padding: 20px;
        background-color: #f5f5f5;
    }

    /* Email Container */
    .email-container {
        font-family: Arial, sans-serif;
        max-width: 600px;
        margin: 0 auto;
        background-color: white;
        padding: 20px;
    }

    /* Typography */
    .email-header {
        margin-bottom: 20px;
    }

    .email-content {
        margin-bottom: 15px;
    }

    .email-footer {
        margin-top: 30px;
        color: #666;
        font-size: 12px;
    }

    /* Buttons */
    .button-container {
        margin: 30px 0;
    }

    .button,
    .verify-button,
    .dashboard-button {
        background-color: #4CAF50;
        color: white;
        padding: 12px 30px;
        text-decoration: none;
        border-radius: 5px;
        display: inline-block;
    }

    .button:hover,
    .verify-button:hover,
    .dashboard-button:hover {
        background-color: #45a049;
        cursor: pointer;
    }

    /* Link Section */
    .copy-link-section {
        color: #666;
        font-size: 14px;
        margin-bottom: 30px;
    }

    .copy-link-section a {
        color: #4CAF50;
        word-break: break-all;
    }

    /* Notice Boxes */
    .security-notice {
        margin-top: 30px;
        padding: 15px;
        background-color: #fff3cd;
        border-left: 4px solid #ffc107;
    }

    .security-notice p {
        margin: 0;
    }

    .security-notice ul {
        margin: 10px 0;
        padding-left: 20px;
    }

    .security-notice li {
        margin: 5px 0;
    }

    .success-notice {
        margin: 20px 0;
        padding: 15px;
        background-color: #d4edda;
        border-left: 4px solid #28a745;
    }

    .success-notice p {
        margin: 0;
    }

    .info-box {
        margin: 20px 0;
        padding: 15px;
        background-color: #e7f3ff;
        border-left: 4px solid #2196F3;
    }

    .info-box h3 {
        margin-top: 0;
    }

    .info-box ul {
        margin: 10px 0;
        padding-left: 20px;
    }

    .info-box li {
        margin: 5px 0;
    }