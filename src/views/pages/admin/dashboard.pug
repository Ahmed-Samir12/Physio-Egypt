extends ../../layouts/main.pug

block vars
  - var pageTitle = 'Admin Dashboard'
  - var pageCrumb = 'الإحصائيات والتقارير'

block pageStyles
  link(rel="stylesheet", href="/css/pages/dashboard.css")

block content

  //- ── Date filter bar ────────────────────────────────────
  .date-filter-bar(style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap")
    label(style="font-family:var(--font-display);font-weight:600;white-space:nowrap") تصفية حسب الفترة
    input#dashDateFrom(type="date" class="input" style="width:auto;min-width:140px")
    span.secondary إلى
    input#dashDateTo(type="date" class="input" style="width:auto;min-width:140px")
    button#dashDateSearch.btn.btn-primary.btn-sm(type="button")
      i(data-lucide="search")
      | عرض
    button#dashDateReset.btn.btn-ghost.btn-sm(type="button") مسح

  //- ── Stat cards ─────────────────────────────────────────
  .grid-stats
    .card.card-pad.card-stat.card-hover.reveal(data-stat-card="todayBookings")
      .stat-icon-wrap.stat-icon-blue
        i(data-lucide="calendar-check")
      .secondary(data-stat-label="todayBookings") حجوزات اليوم
      .stat-value.tnum(data-stat-value="todayBookings") —
    .card.card-pad.card-stat.card-hover.reveal(data-stat-card="todayDeposits")
      .stat-icon-wrap.stat-icon-green
        i(data-lucide="banknote")
      .secondary(data-stat-label="todayDeposits") عربون اليوم
      .stat-value.tnum(data-stat-value="todayDeposits") —
    .card.card-pad.card-stat.card-hover.reveal(data-stat-card="allBookings")
      .stat-icon-wrap.stat-icon-purple
        i(data-lucide="layers")
      .secondary(data-stat-label="allBookings") إجمالي الحجوزات
      .stat-value.tnum(data-stat-value="allBookings") —
    .card.card-pad.card-stat.card-hover.reveal(data-stat-card="allRevenue")
      .stat-icon-wrap.stat-icon-amber
        i(data-lucide="trending-up")
      .secondary(data-stat-label="allRevenue") إجمالي الإيرادات
      .stat-value.tnum(data-stat-value="allRevenue") —
    .card.card-pad.card-stat.card-hover.reveal(data-stat-card="allDeposits")
      .stat-icon-wrap.stat-icon-green
        i(data-lucide="wallet")
      .secondary إجمالي العربون الكلي
      .stat-value.tnum(data-stat-value="allDeposits") —
    .card.card-pad.card-stat.card-hover.reveal(data-stat-card="projectedRevenue")
      .stat-icon-wrap.stat-icon-purple
        i(data-lucide="bar-chart-2")
      .secondary الإيراد المتوقع
      .stat-value.tnum(data-stat-value="projectedRevenue") —
      .secondary(style="font-size:1.5rem;margin-top:.25rem") خصم الإسترداد: #[span.tnum(data-retrieval-discount) —]
      .secondary(style="font-size:1.5rem") الصافي: #[span.tnum(data-net-projected) —]

  //- ── Charts row ─────────────────────────────────────────
  .charts-row
    //- Donut chart
    .card.card-pad.card-glass.reveal
      h3.section-card-title توزيع الحالات
      .donut-wrap
        canvas#donutChart(width="180", height="180")
      .donut-legend
        .legend-item
          span.legend-dot(style="background:var(--warning)")
          span.legend-label قيد الانتظار
          span.legend-count.tnum(data-status-pending) —
        .legend-item 
          span.legend-dot(style="background:#22c55e")
          span.legend-label مؤكد
          span.legend-count.tnum(data-status-confirmed) —
        .legend-item
          span.legend-dot(style="background:#6366f1")
          span.legend-label مكتمل
          span.legend-count.tnum(data-status-done) —
        .legend-item
          span.legend-dot(style="background:var(--accent)")
          span.legend-label مسترد
          span.legend-count.tnum(data-status-retrieval) —
        .legend-item
          span.legend-dot(style="background:var(--danger)")
          span.legend-label ملغى
          span.legend-count.tnum(data-status-cancelled) —

    //- Revenue summary
    .card.card-pad.card-glass.reveal
      h3.section-card-title ملخص الإيرادات
      .revenue-grid
        .rev-item
          .rev-label إجمالي اليوم
          .rev-val.tnum(data-rev-today) —
        .rev-item
          .rev-label العربون المحصّل
          .rev-val.tnum.green(data-rev-deposits) —
        .rev-item
          .rev-label المبلغ المتبقي
          .rev-val.tnum.amber(data-rev-remaining) —

  //- ── Employee performance ────────────────────────────────
  .section
    .section-head
      h3 أداء الموظفين
    .card.card-pad.card-glass.reveal
      .table-wrap
        table.table
          thead
            tr
              th #
              th الاسم
              th البريد الإلكتروني
              th الحجوزات
              th الإيرادات
              th العربون
          tbody(data-perf-body)

  //- ── All bookings table ──────────────────────────────────
  .section
    .section-head
      h3 الحجوزات
      .chips
        button.chip.is-active(type="button", data-status-chip="all") الكل
        button.chip(type="button", data-status-chip="pending") قيد الانتظار
        button.chip(type="button", data-status-chip="confirmed") مؤكد
        button.chip(type="button", data-status-chip="done") مكتمل
        button.chip(type="button", data-status-chip="retrieval") مسترد
        button.chip(type="button", data-status-chip="cancelled") ملغى
    .card.card-pad.card-glass.reveal
      .table-wrap
        table.table
          thead
            tr
              th التاريخ
              th الوقت
              th المريض
              th الخدمة
              th الحالة
              th الإجمالي
              th الإجراءات
          tbody(data-bookings-body)

block pageScripts
  script(src="/js/vendor/chart.umd.min.js")
  script(type="module", src="/js/pages/admin.js")
