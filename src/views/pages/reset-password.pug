doctype html
html(lang="ar" dir="rtl")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Reset Password · فيزيو إيجيبت
    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Syne:wght@700&display=swap", rel="stylesheet")
    link(rel="stylesheet", href="/css/base.css")
    link(rel="stylesheet", href="/css/components.css")
    link(rel="stylesheet", href="/css/pages/login.css")
    script(src="/js/vendor/lucide.min.js")
    style.
      /* Smooth transitions between 3 reset-password states */
      .auth-view {
        display: grid !important;
        opacity: 0;
        transform: translateY(10px);
        pointer-events: none;
        transition: opacity 220ms ease, transform 220ms ease;
      }
      .auth-view.is-active {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }

      .error-x-wrap {
        text-align: center;
        padding: 1.05rem 0;
      }

      .error-x-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: rgba(239, 68, 68, 0.08);
        border: 1px solid rgba(239, 68, 68, 0.25);
        position: relative;
        margin: 0 auto 1.05rem;
        box-shadow: 0 4px 20px rgba(239, 68, 68, 0.12);
      }

      .error-x-icon::before,
      .error-x-icon::after {
        content: '';
        position: absolute;
        left: 50%;
        top: 50%;
        width: 40px;
        height: 7px;
        background: #ef4444;
        border-radius: 999px;
        transform-origin: center;
      }

      .error-x-icon::before {
        transform: translate(-50%, -50%) rotate(45deg);
      }

      .error-x-icon::after {
        transform: translate(-50%, -50%) rotate(-45deg);
      }

  body
    .login-shell
      .login-left
        .pattern
        .shapes
        .hero.reveal(style="--d:80ms")
          h1 إعادة تعيين#[br]كلمة المرور.
          p أدخل كلمة مرور جديدة للوصول إلى حسابك.

      .login-right
        .card.login-card.reveal(style="--d:140ms")
          #reset-token(data-token=token, style="display:none")
          #view-reset.auth-view.is-active
            h2 إعادة تعيين كلمة المرور
            p.sub أدخل كلمة مرور جديدة قوية لحسابك.
            .auth-view-form
              .field
                label.label(for="new-password") كلمة المرور الجديدة
                .input-group
                  input#new-password.input.with-suffix(type="password", placeholder="8 أحرف على الأقل", required)
                  button.btn.btn-ghost.btn-sm.pw-toggle(type="button", aria-label="Show password", data-pw-toggle)
                    i(data-lucide="eye")
              .field
                label.label(for="confirm-password") تأكيد كلمة المرور
                .input-group
                  input#confirm-password.input.with-suffix(type="password", placeholder="أعد كلمة المرور الجديدة", required)
                  button.btn.btn-ghost.btn-sm.pw-toggle(type="button", aria-label="Show password", data-pw-toggle)
                    i(data-lucide="eye")
              .login-actions
                button.btn.btn-primary(type="button", style="width:100%", id="reset-submit")
                  span#reset-btn-text إعادة التعيين

          #view-done.auth-view
            .error-done-wrap
              .done-icon ✓
              h2 تم تغيير كلمة المرور بنجاح ✓
              p.sub يمكنك الآن تسجيل الدخول والبدء في استخدام النظام.
              a.btn.btn-primary(href="/login", style="margin-top:1rem;width:100%") تسجيل الدخول

          #view-error.auth-view
            .error-x-wrap
              .error-x-icon(aria-hidden="true")
              h2 انتهت صلاحية الرابط أو تم استخدامه مسبقاً.
              a.btn.btn-primary(href="/login", style="margin-top:1rem;width:100%") طلب رابط جديد

    script(type="module").
      import { initReveal } from '/js/components/reveal.js';
      initReveal();

    script(type="module", src="/js/pages/reset-password.js")
