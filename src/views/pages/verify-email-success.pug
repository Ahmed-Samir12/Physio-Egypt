doctype html
html(lang="ar" dir="rtl")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title تم تفعيل حسابك · Physio Egypt
    link(rel="icon", type="image/jpeg", href="/images/icon.jpeg")
    link(rel="apple-touch-icon", href="/images/icon.jpeg")

    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet")

    link(rel="stylesheet", href="/css/base.css")
    link(rel="stylesheet", href="/css/components.css")
    link(rel="stylesheet", href="/css/pages/login.css")
    script(src="/js/vendor/lucide.min.js")

    style.
      .verify-success-icon {
        width: 84px;
        height: 84px;
        border-radius: 50%;
        background: linear-gradient(135deg, #22c55e, #16a34a);
        margin: 0 auto 1.1rem;
        box-shadow: 0 4px 20px rgba(34, 197, 94, 0.35);
        position: relative;
        transform: scale(0.96);
        animation: verifyPop 420ms ease-out forwards;
      }

      .verify-success-icon::before {
        content: '';
        position: absolute;
        left: 50%;
        top: 50%;
        width: 34px;
        height: 18px;
        border-left: 6px solid #fff;
        border-bottom: 6px solid #fff;
        transform: translate(-50%, -58%) rotate(-45deg);
        transform-origin: left top;
        opacity: 0;
        animation: verifyCheckIn 520ms ease-out 140ms forwards;
      }

      @keyframes verifyPop {
        to { transform: scale(1); }
      }

      @keyframes verifyCheckIn {
        from { opacity: 0; transform: translate(-50%, -58%) rotate(-45deg) scale(0.9); }
        to { opacity: 1; transform: translate(-50%, -58%) rotate(-45deg) scale(1); }
      }

      .verify-success-wrap {
        text-align: center;
        padding: 0.5rem 0 0;
      }

  body
    .login-shell
      .login-left
        .pattern
        .shapes
        .hero.reveal(style="--d:80ms")
          .login-brand
            img(src="/images/logo.jpeg", alt="Physio Egypt", width="80", height="55")
          h1 Physio Egypt
          p.login-tagline خدمات العلاج الطبيعي المنزلي
          p.login-sub جميع محافظات مصر

      .login-right
        .card.login-card.reveal(style="--d:140ms")
          .verify-success-wrap
            .verify-success-icon(aria-hidden="true")
            h2 تم تفعيل حسابك بنجاح 🎉
            p.sub يمكنك الآن تسجيل الدخول والبدء في استخدام النظام.
            a.btn.btn-primary(type="button", href="/login", style="width:100%;margin-top:1.2rem;text-decoration:none;display:inline-flex;justify-content:center")
              | تسجيل الدخول الآن

    script(type="module").
      window.lucide?.createIcons?.({ attrs: { 'stroke-width': 1.8 } });
      import { initReveal } from '/js/components/reveal.js';
      initReveal();

