doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Sign In · Physio Egypt
    link(rel="icon", type="image/jpeg", href="/images/icon.jpeg")
    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Syne:wght@700;800&display=swap", rel="stylesheet")
    link(rel="stylesheet", href="/css/base.css")
    link(rel="stylesheet", href="/css/components.css")
    link(rel="stylesheet", href="/css/pages/login.css")
    script(src="/js/vendor/lucide.min.js")
  body
    .login-shell
      .login-left
        .pattern
        .shapes
        .hero.reveal(style="--d:80ms")
          .login-brand
            img(src="/images/logo.jpeg", alt="Physio Egypt", width="80", height="55")
          h1 Physio Egypt
          p.login-tagline خدمات العلاج الطبيعي المنزلي
          p.login-sub جميع محافظات مصر
      .login-right
        .card.login-card.reveal(style="--d:140ms")

          //- ── Sign In ─────────────────────────────────────
          #view-login.auth-view.is-active
            .login-card-header
              .login-card-icon
                i(data-lucide="log-in")
              div
                h2 مرحباً بك
                p.sub سجّل دخولك إلى نظام فيزيو إيجيبت.
            .auth-view-form
              .field
                label.label(for="login-email") البريد الإلكتروني
                input#login-email.input(type="email", placeholder="البريد الإلكتروني", autocomplete="username", required)
              .field
                label.label(for="login-password") كلمة المرور
                .input-group
                  input#login-password.input.with-suffix(type="password", placeholder="••••••••", autocomplete="current-password", required)
                  button.btn.btn-ghost.btn-sm.pw-toggle(type="button", aria-label="Show password", data-pw-toggle)
                    i(data-lucide="eye")
              .login-actions
                button.btn.btn-primary(type="button", style="width:100%", data-login-submit)
                  span(data-login-btn-text) تسجيل الدخول
                .inline-error.hidden(data-login-error)
              .auth-links
                button.auth-link(type="button", data-show="view-forgot") نسيت كلمة المرور؟
                button.auth-link(type="button", data-show="view-register") إنشاء حساب

          //- ── Register ────────────────────────────────────
          #view-register.auth-view
            .login-card-header
              .login-card-icon.icon-green
                i(data-lucide="user-plus")
              div
                h2 إنشاء حساب
                p.sub إنشاء حساب موظف جديد.
            .auth-view-form
              .field
                label.label(for="reg-name") الاسم الكامل
                input#reg-name.input(type="text", placeholder="الاسم الكامل", required)
              .field
                label.label(for="reg-email") البريد الإلكتروني
                input#reg-email.input(type="email", placeholder="البريد الإلكتروني", required)
              .field
                label.label(for="reg-password") كلمة المرور
                .input-group
                  input#reg-password.input.with-suffix(type="password", placeholder="8 أحرف على الأقل", required)
                  button.btn.btn-ghost.btn-sm.pw-toggle(type="button", data-pw-toggle)
                    i(data-lucide="eye")
              .field
                label.label(for="reg-password-confirm") تأكيد كلمة المرور
                .input-group
                  input#reg-password-confirm.input.with-suffix(type="password", placeholder="أعد كتابة كلمة المرور", required)
                  button.btn.btn-ghost.btn-sm.pw-toggle(type="button", data-pw-toggle)
                    i(data-lucide="eye")
              .login-actions
                button.btn.btn-primary(type="button", style="width:100%", data-reg-submit)
                  span(data-reg-btn-text) إنشاء حساب
                .inline-error.hidden(data-reg-error)
                .inline-error.hidden(data-reg-success)
              .auth-links
                span لديك حساب بالفعل؟
                button.auth-link(type="button", data-show="view-login") تسجيل الدخول

          //- ── Forgot Password ──────────────────────────────
          #view-forgot.auth-view
            .login-card-header
              .login-card-icon.icon-amber
                i(data-lucide="key-round")
              div
                h2 استرداد كلمة المرور
                p.sub سنرسل رابط الاسترداد إلى بريدك الإلكتروني.
            .auth-view-form
              .field
                label.label(for="forgot-email") البريد الإلكتروني
                input#forgot-email.input(type="email", placeholder="البريد الإلكتروني", required)
              .login-actions
                button.btn.btn-primary(type="button", style="width:100%", data-forgot-submit)
                  span(data-forgot-btn-text) إرسال رابط الاسترداد
                .inline-error.hidden(data-forgot-error)
                .inline-error.hidden(data-forgot-success)
              .auth-links
                button.auth-link(type="button", data-show="view-login")
                  i(data-lucide="arrow-left", style="display:inline;width:13px;height:13px;vertical-align:-2px;margin-right:3px")
                  | العودة إلى تسجيل الدخول

    script(type="module", src="/js/pages/login.js")
    script.
      window.lucide?.createIcons?.({ attrs: { 'stroke-width': 1.8 } });
    script(type="module").
      import { initReveal } from '/js/components/reveal.js';
      initReveal();
