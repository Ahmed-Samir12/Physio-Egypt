extends ../../layouts/main.pug

block vars
  - var pageTitle = 'Patients'
  - var pageCrumb = 'Patient directory'

block pageStyles
  link(rel="stylesheet", href="/css/pages/patients.css")

block content
  .toolbar
    .toolbar-left
      .search-wrap(style="width:min(420px,60vw)")
        i(data-lucide="search")
        input.input.search-input(type="search", placeholder="ابحث باسم المريض أو الهاتف…", data-patients-search, autocomplete="off")
    .toolbar-right
      span.secondary(data-total) —
      a.btn.btn-primary(href="/bookings/new")
        i(data-lucide="user-plus")
        | مريض جديد

  .patient-grid(data-patient-grid)

  .pagination
    button.pager(type="button", data-prev)
      i(data-lucide="chevron-right")
      | السابق
    span.secondary(data-page-info) —
    button.pager(type="button", data-next)
      | التالي
      i(data-lucide="chevron-left")

block pageScripts
  script(type="module", src="/js/pages/patients.js")
