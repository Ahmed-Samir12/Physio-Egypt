doctype html
html(lang="ar" dir="rtl")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title رابط التفعيل غير صالح · Physio Egypt
    link(rel="icon", type="image/jpeg", href="/images/icon.jpeg")
    link(rel="apple-touch-icon", href="/images/icon.jpeg")

    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet")

    link(rel="stylesheet", href="/css/base.css")
    link(rel="stylesheet", href="/css/components.css")
    link(rel="stylesheet", href="/css/pages/login.css")
    script(src="/js/vendor/lucide.min.js")

    style.
      .verify-error-icon {
        width: 84px;
        height: 84px;
        border-radius: 50%;
        background: rgba(239, 68, 68, 0.08);
        border: 1px solid rgba(239, 68, 68, 0.25);
        margin: 0 auto 1.1rem;
        position: relative;
        box-shadow: 0 4px 20px rgba(239, 68, 68, 0.12);
        transform: scale(0.96);
        animation: verifyPop 420ms ease-out forwards;
      }

      .verify-error-icon::before,
      .verify-error-icon::after {
        content: '';
        position: absolute;
        left: 50%;
        top: 50%;
        width: 42px;
        height: 7px;
        background: #ef4444;
        border-radius: 999px;
        transform-origin: center;
        opacity: 0;
        animation: xIn 520ms ease-out 140ms forwards;
      }

      .verify-error-icon::before {
        transform: translate(-50%, -50%) rotate(45deg);
      }

      .verify-error-icon::after {
        transform: translate(-50%, -50%) rotate(-45deg);
      }

      @keyframes verifyPop {
        to { transform: scale(1); }
      }

      @keyframes xIn {
        from { opacity: 0; transform: translate(-50%, -50%) rotate(0deg) scale(0.85); }
        to { opacity: 1; }
      }

      .verify-error-wrap {
        text-align: center;
        padding: 0.5rem 0 0;
      }

      .resend-form {
        display: grid;
        gap: 0.8rem;
        margin-top: 1.2rem;
      }

      .resend-msg {
        min-height: 1.25rem;
        font-size: 0.9rem;
        color: var(--text-secondary);
      }

  - const reasonSafe = reason || 'invalid';
  - const subText = reasonSafe === 'expired' ? 'انتهت صلاحية رابط التفعيل. اطلب رابطاً جديداً.' : 'هذا الرابط غير صالح أو تم استخدامه مسبقاً.';

  body
    .login-shell
      .login-left
        .pattern
        .shapes
        .hero.reveal(style="--d:80ms")
          .login-brand
            img(src="/images/logo.jpeg", alt="Physio Egypt", width="80", height="55")
          h1 Physio Egypt
          p.login-tagline خدمات العلاج الطبيعي المنزلي
          p.login-sub جميع محافظات مصر

      .login-right
        .card.login-card.reveal(style="--d:140ms")
          .verify-error-wrap
            .verify-error-icon(aria-hidden="true")
            h2 رابط التفعيل غير صالح
            p.sub= subText

            .resend-form
              .field
                label.label(for="resend-email") البريد الإلكتروني
                input#resend-email.input(type="email", placeholder="example@email.com", required)
              button.btn.btn-primary(type="button", id="resend-submit", style="width:100%")
                | طلب رابط جديد

              p.resend-msg#resend-msg —

              a.btn.btn-ghost(type="button", href="/login", style="width:100%;text-decoration:none;display:inline-flex;justify-content:center;")
                | العودة لتسجيل الدخول

    script(type="module").
      import { initReveal } from '/js/components/reveal.js';
      initReveal();

      const btn = document.getElementById('resend-submit');
      const emailEl = document.getElementById('resend-email');
      const msgEl = document.getElementById('resend-msg');

      function setMsg(text) {
        if (!msgEl) return;
        msgEl.textContent = text || '';
      }

      btn?.addEventListener('click', async () => {
        const email = emailEl?.value?.trim();
        if (!email) {
          setMsg('يرجى إدخال البريد الإلكتروني.');
          return;
        }

        btn.disabled = true;
        btn.textContent = 'جارٍ الإرسال…';

        try {
          const res = await fetch('/api/v1/auth/resend-verification', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(data?.message || 'فشل الإرسال');
          setMsg(data?.message || 'تم إرسال رابط جديد إذا كان البريد مسجلاً.');
        } catch (e) {
          setMsg(e?.message || 'تعذر إرسال الرابط. حاول مرة أخرى.');
        } finally {
          btn.disabled = false;
          btn.textContent = 'طلب رابط جديد';
        }
      });

