extends ../../layouts/main.pug

block vars
  - var pageTitle = 'تفاصيل الحجز'
  - var pageCrumb = 'تفاصيل الموعد'

block pageStyles
  link(rel="stylesheet", href="/css/pages/bookings.css")

block content
  .booking-detail-grid

    //- ── Left column ──────────────────────────────────────
    .booking-left

      //- Patient info card
      .card.card-pad.reveal
        .section-label
          i(data-lucide="user")
          span بيانات المريض
        .patient-name-row
          h2.patient-name(data-patient-name) —
          .patient-badges
            span.badge.badge-muted(data-patient-gender) —
            span.badge.badge-muted(data-patient-age) —
            span.badge.badge-muted(data-patient-id) —
            span.badge.badge-muted.hidden(data-patient-nationality)
        .patient-phone-row
          button.btn.btn-ghost.btn-sm(type="button", data-call-phone, title="اتصل بالمريض")
            i(data-lucide="phone")
            span(data-phone-display) —
          a.btn.btn-ghost.btn-sm(data-whatsapp-link, href="#", target="_blank", rel="noopener", title="واتساب")
            i(data-lucide="message-circle")
            | واتساب
        .companion-row.hidden(data-companion-row)
          i(data-lucide="users")
          span.companion-label المرافق:
          span(data-companion-name) —
        .info-row.hidden(data-complaint-row, style="margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--border)")
          .info-label الشكوى
          .info-val(data-complaint-val) —
        .info-row(data-notes-row, style="margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--border)")
          .info-label ملاحظات
          .info-val(data-notes-val) —

      //- Appointment info
      .card.card-pad.reveal
        .section-label
          i(data-lucide="calendar-check")
          span بيانات الموعد
        .info-grid
          .info-row
            .info-label التاريخ
            .info-val(data-booking-date) —
          .info-row
            .info-label الوقت
            .info-val(data-booking-time) —
          .info-row
            .info-label الخدمة
            .info-val(data-booking-service) —
          .info-row
            .info-label بواسطة
            .info-val(data-booking-createdby) —

      //- Patient card section
      .card.card-pad.reveal
        .section-label
          i(data-lucide="printer")
          span بطاقة المريض
        p.secondary(style="margin-bottom:.85rem") اطبع أو شارك بطاقة الحجز مع المريض.
        .btn-row
          button.btn.btn-primary(type="button", data-download-card)
            i(data-lucide="download")
            | تنزيل PDF
          button.btn.btn-whatsapp(type="button", data-share-card-wa)
            svg(viewBox="0 0 24 24", fill="currentColor", width="16", height="16", style="flex-shrink:0")
              path(d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z")
            | إرسال عبر واتساب
        p.secondary(style="margin-top:.6rem;font-size:.78rem") شارك الرسالة ثم أرفق البطاقة يدوياً

    //- ── Right column ─────────────────────────────────────
    .booking-right

      //- Status & actions
      .card.card-pad.reveal
        .section-label
          i(data-lucide="git-branch")
          span الحالة والإجراءات
        .timeline
          span.step(data-step="pending")
            i(data-lucide="clock")
            | قيد الانتظار
          span.step-arrow ›
          span.step(data-step="confirmed")
            i(data-lucide="check")
            | مؤكد
          span.step-arrow ›
          span.step(data-step="done")
            i(data-lucide="check-check")
            | مكتمل
          span.step-arrow ›
          span.step(data-step="retrieval")
            i(data-lucide="heart-pulse")
            | مسترد
        .status-actions
          select.select(data-status-select)
            option(value="pending") قيد الانتظار
            option(value="confirmed") مؤكد
            option(value="done") مكتمل
            option(value="retrieval") مسترد
            option(value="cancelled") ملغى
          button.btn.btn-success(type="button", data-confirm-btn)
            i(data-lucide="check-circle")
            | تأكيد الحجز
          button.btn.btn-danger(type="button", data-cancel)
            i(data-lucide="x-circle")
            | إلغاء

      //- Payment
      .card.card-pad.reveal
        .section-label
          i(data-lucide="banknote")
          span الدفع
        .split-row
          .field
            label.label إجمالي السعر (EGP)
            input.input(type="number", min="0", step="1", data-total)
          .field
            label.label العربون المدفوع (EGP)
            input.input(type="number", min="0", step="1", data-deposit)
        .remaining-card
          .remaining-label
            i(data-lucide="alert-circle")
            | المبلغ المتبقي
          .remaining-amount(data-remaining) —

      //- Edit booking details
      .card.card-pad.reveal
        .section-label
          i(data-lucide="pencil")
          span تعديل الموعد
        .field
          label.label نوع الخدمة
          input.input(type="text", placeholder="زيارة منزلية / استشارة…", data-edit-service, list="edit-services")
          datalist#edit-services
            option(value="زيارة منزلية")
            option(value="استشارة")
            option(value="تحاليل")
        .split-row
          .field
            label.label التاريخ
            input.input(type="date", data-edit-date, dir="ltr")
          .field
            label.label الوقت
            input.input(type="time", data-edit-time, dir="ltr")
        .field
          label.label ملاحظات الموعد
            span.field-optional  (اختياري)
          textarea.textarea(rows="2", placeholder="ملاحظات…", data-edit-notes)
        button.btn.btn-primary(type="button", data-save-booking-btn, style="margin-top:.5rem;width:100%")
          i(data-lucide="save")
          span حفظ التعديلات

      //- Edit patient
      .card.card-pad.reveal
        .section-label
          i(data-lucide="user-pen")
          span تعديل بيانات المريض
        .field
          label.label الاسم الكامل
          input.input(type="text", placeholder="الاسم", data-edit-p-name)
        .split-row
          .field
            label.label رقم الهاتف
            input.input(type="tel", placeholder="01XXXXXXXXX", data-edit-p-phone, dir="ltr")
          .field
            label.label العمر
            input.input(type="number", min="0", placeholder="السن", data-edit-p-age)
        .field
          label.label الجنس
          .pill-group(data-edit-p-gender)
            label.pill
              input(type="radio", name="edit-gender", value="male")
              span ذكر
            label.pill
              input(type="radio", name="edit-gender", value="female")
              span أنثى
        .field
          label.label الجنسية
          input.input(type="text", placeholder="مصري / سعودي…", data-edit-p-nationality)
        .field
          label.label الشكوى
          input.input(type="text", placeholder="ماذا يشكو المريض؟", data-edit-p-complaint)
        .field
          label.label المرافق
            span.field-optional  (اختياري)
          input.input(type="text", placeholder="اسم المرافق", data-edit-companion)
        .field
          label.label رقم الواتساب
            span.field-optional  (اختياري)
          input.input(type="tel", placeholder="01XXXXXXXXX", data-edit-p-whatsapp, dir="ltr")
        .field
          label.label ملاحظات
            span.field-optional  (اختياري)
          textarea.textarea(rows="2", placeholder="ملاحظات عن المريض…", data-edit-p-notes)
        button.btn.btn-primary(type="button", data-save-patient-btn, style="margin-top:.5rem;width:100%")
          i(data-lucide="save")
          span حفظ بيانات المريض

block pageScripts
  script(type="module", src="/js/pages/bookings-detail.js")
