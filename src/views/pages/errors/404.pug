doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    link(rel="icon", type="image/jpeg", href="/images/icon.jpeg")
    title 404 · الصفحة غير موجودة · Physio Egypt
    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Syne:wght@700&display=swap", rel="stylesheet")
    link(rel="stylesheet", href="/css/base.css")
    link(rel="stylesheet", href="/css/components.css")
    link(rel="stylesheet", href="/css/pages/errors.css")
    script(src="/js/vendor/lucide.min.js")
  body
    .error-shell
      .error-card.reveal
        .error-icon-wrap
          .error-blob
          .error-icon
            i(data-lucide="map-pin-off")
        .error-code 404
        h1.error-title الصفحة غير موجودة
        p.error-msg الصفحة التي تبحث عنها غير موجودة أو تم نقلها.
        .error-url(data-url)
        .error-actions
          a.btn.btn-primary(href="/dashboard")
            i(data-lucide="layout-dashboard")
            | الذهاب إلى لوحة التحكم
          a.btn.btn-ghost(href="javascript:history.back()")
            i(data-lucide="arrow-left")
            | الرجوع
    script.
      window.lucide?.createIcons?.({ attrs: { 'stroke-width': 1.8 } });
      const u = document.querySelector('[data-url]');
      if (u) u.textContent = window.location.pathname;
    script(type="module").
      import { initReveal } from '/js/components/reveal.js';
      initReveal();
